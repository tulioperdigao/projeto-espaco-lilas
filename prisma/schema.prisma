generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url  	    = env("DATABASE_URL")
}

model Procedures {
  id String @id @default(uuid())
  name String
  description String?
  durationInMinutes Int
  price Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
}
